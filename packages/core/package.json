{
  "name": "@zzapi-mes/core",
  "version": "0.1.0",
  "description": "SAP client, Zod schemas, and shared types for ZZAPI MES",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./transform": {
      "types": "./dist/transform/index.d.ts",
      "default": "./dist/transform/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "pretest": "tsc",
    "test": "node --test --test-concurrency=2 dist/test/*.test.js",
    "prepublishOnly": "pnpm run build"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
