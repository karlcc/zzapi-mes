# zzapi-mes hub environment variables
# Copy to /etc/zzapi-mes-hub.env and fill in values.
# chmod 600 /etc/zzapi-mes-hub.env (contains secrets)

# Hub config
HUB_PORT=8080
HUB_JWT_SECRET=replace-with-openssl-rand-base64-32
# HUB_JWT_TTL_SECONDS=900
# HUB_DB_PATH=/var/lib/zzapi-mes-hub/hub.db
# HUB_CORS_ORIGIN=*            # default: any origin. Set comma-separated list to restrict, empty string to disable
# HUB_AUDIT_RETENTION_DAYS=90  # prune audit_log rows older than N days on startup (default 90)

# SAP backend (the hub holds these so clients don't need them)
SAP_HOST=sap.example.internal:8000
SAP_CLIENT=200
SAP_USER=replace-me
SAP_PASS=replace-me
